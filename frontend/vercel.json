{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/frontend",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://fund-research-dashboard.onrender.com/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
